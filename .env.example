# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy this file to .env and fill in your real values.
# Run `cp .env.example .env` and then edit .env.
# NEVER commit .env — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL password for the n8n_user database account (min 12 chars)
POSTGRES_PASSWORD=your_strong_postgres_password_here

# n8n web dashboard password (min 12 chars)
N8N_PASSWORD=your_strong_n8n_dashboard_password_here

# Groq API key — free at https://console.groq.com (starts with gsk_)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Gmail address used by the bot
GMAIL_ADDRESS=your-email@gmail.com

# Gmail App Password (16 chars, no spaces) — generated at
# myaccount.google.com → Security → 2-Step Verification → App Passwords
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# Google Sheets Spreadsheet ID — the long ID from the sheet URL:
# docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# Your display name (used in email sign-offs)
YOUR_NAME=Your Name

# Your company name
YOUR_COMPANY=Your Company Name
